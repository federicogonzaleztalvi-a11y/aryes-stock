{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/chat.js":       { "maxDuration": 30 },
    "api/admin-users.js":{ "maxDuration": 15 },
    "api/catalogo.js":   { "maxDuration": 10 },
    "api/pedido.js":     { "maxDuration": 10 },
    "api/otp-send.js":   { "maxDuration": 15 },
    "api/otp-verify.js": { "maxDuration": 10 }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
