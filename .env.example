# ─────────────────────────────────────────────────────────────────────────────
# Aryes Stock — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local for local development.
# .env.local is gitignored — NEVER commit real values to source control.
#
# Production (Vercel):
#   Dashboard → Project → Settings → Environment Variables
#   Add each REQUIRED variable below.
#
# VITE_* variables are inlined into the browser bundle at build time.
# Non-VITE_ variables are only available in Vercel serverless functions.
# ─────────────────────────────────────────────────────────────────────────────

# ── REQUIRED — Frontend ───────────────────────────────────────────────────────
# Get from: Supabase Dashboard → Project → Settings → API

VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...your_anon_key_here...

# ── REQUIRED — Serverless functions ───────────────────────────────────────────
# Get from: Supabase Dashboard → Project → Settings → API → service_role key
# WARNING: This key bypasses ALL Row Level Security. Never expose to the browser.

SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...your_service_role_key_here...
SUPABASE_ANON_KEY=eyJ...your_anon_key_here...

# ── REQUIRED — AI assistant ───────────────────────────────────────────────────
# Get from: https://console.anthropic.com → API Keys

ANTHROPIC_KEY=sk-ant-...your_key_here...

# ── OPTIONAL — CORS / deployment ─────────────────────────────────────────────
# Defaults to https://aryes-stock.vercel.app if not set.
# Override if you deploy to a custom domain.

APP_URL=https://your-custom-domain.com
